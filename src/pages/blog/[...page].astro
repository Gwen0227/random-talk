---
import BlogCard from '@/components/BlogCard.astro'
import Breadcrumbs from '@/components/Breadcrumbs.astro'
import PageHead from '@/components/PageHead.astro'
import PaginationComponent from '@/components/ui/pagination'
import { SITE } from '@/consts'
import Layout from '@/layouts/Layout.astro'
import { getAllPosts, groupPostsByYear } from '@/lib/data-utils'
import type { PaginateFunction } from 'astro'

export async function getStaticPaths({
  paginate,
}: {
  paginate: PaginateFunction
}) {
  const allPosts = await getAllPosts()
  return paginate(allPosts, { pageSize: SITE.postsPerPage })
}

const { page } = Astro.props

// 🔥 抓所有文章（用來產生分類）
const allPosts = await getAllPosts()

// 🔥 收集所有 tags
const tagMap = new Map()

allPosts.forEach(post => {
  post.data.tags?.forEach(tag => {
    tagMap.set(tag, (tagMap.get(tag) || 0) + 1)
  })
})

// 👉 轉成 array 並排序（文章多的排前面）
const tags = Array.from(tagMap.entries())
  .sort((a, b) => b[1] - a[1])

// 👉 原本的文章分組
const postsByYear = groupPostsByYear(page.data)
const years = Object.keys(postsByYear).sort((a, b) => parseInt(b) - parseInt(a))

// 處理 GitHub Pages 路徑
const base = import.meta.env.BASE_URL.replace(/\/$/, '')
const paginationBaseUrl = `${base}/blog/`
---

<Layout class="max-w-3xl">
  <PageHead slot="head" title="Blog" />
  
  <Breadcrumbs
    items={[
      { label: 'Blog', href: `${base}/blog`, icon: 'lucide:library-big' },
      { label: `Page ${page.currentPage}`, icon: 'lucide:book-copy' },
    ]}
  />

  {/* 🔥 自動分類 UI */}
  <div class="flex flex-wrap gap-3 my-8 font-sans">
    <a 
      href={`${base}/blog`} 
      class="flex-1 min-w-[80px] py-2.5 px-4 bg-muted/50 hover:bg-muted text-center rounded-lg transition-all border border-border/40 text-sm font-medium text-foreground"
    >
      All
    </a>

    {tags.map(([tag, count]) => (
      <a 
        href={`${base}/tags/${tag}`}
        class="flex-1 min-w-[80px] py-2.5 px-4 bg-muted/50 hover:bg-muted text-center rounded-lg transition-all border border-border/40 text-sm font-medium text-foreground"
      >
        {tag} ({count})
      </a>
    ))}
  </div>

  <div class="flex min-h-[calc(100vh-18rem)] flex-col gap-y-10">
    {
      years.map((year) => (
        <section class="flex flex-col gap-y-5">
          <div class="text-xl font-bold text-foreground/80 border-b border-border/30 pb-2 italic">
            {year}
          </div>
          <ul id="post-container" class="flex flex-col gap-6">
            {postsByYear[year].map((post) => (
              <li>
                <BlogCard entry={post} />
              </li>
            ))}
          </ul>
        </section>
      ))
    }
  </div>

  <div class="mt-12">
    <PaginationComponent
      currentPage={page.currentPage}
      totalPages={page.lastPage}
      baseUrl={paginationBaseUrl}
      client:load
    />
  </div>
</Layout>

<style>
  a:active {
    transform: scale(0.98);
  }
</style>