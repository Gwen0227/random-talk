---
// src/components/Cusdis.astro
const { pageId, pageUrl, pageTitle } = Astro.props;

// 請確認這兩個值與你 Cusdis 後台完全一致
const HOST = "https://mycusdis.vercel.app";
const APP_ID = "0cc60d4f-6bae-4446-878d-43af68445b0e";

// 構建直接與 API 對接的網址
const iframeSrc = `${HOST}/api/iframe?appId=${APP_ID}&pageId=${pageId}&pageUrl=${encodeURIComponent(pageUrl)}&pageTitle=${encodeURIComponent(pageTitle)}`;
---

<div class="cusdis-container mt-16 pt-8 border-t border-border/40">
  <iframe
    src={iframeSrc}
    style="width: 100%; min-height: 500px; border: 0;"
    id="cusdis-iframe"
    title="Cusdis Comments"
    loading="lazy"
  ></iframe>
</div>

<script is:inline>
  // 處理 iframe 的高度自適應，讓留言板不會出現雙重捲軸
  window.addEventListener('message', (e) => {
    try {
      const data = JSON.parse(e.data);
      if (data.target === 'cusdis' && data.type === 'resize') {
        const iframe = document.getElementById('cusdis-iframe');
        if (iframe) {
          iframe.style.height = data.data + 'px';
        }
      }
    } catch (err) {
      // 忽略非 JSON 或非 Cusdis 的訊息
    }
  });

  // 針對 Astro View Transitions：確保換頁時 iframe 會重新載入
  document.addEventListener('astro:page-load', () => {
    const iframe = document.getElementById('cusdis-iframe');
    if (iframe) {
      // 強制刷新 iframe 確保抓到正確文章的留言
      iframe.src = iframe.src;
    }
  });
</script>