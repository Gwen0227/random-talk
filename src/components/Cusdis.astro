---
// 接收來自父層的資料
const { pageId, pageUrl, pageTitle } = Astro.props;
---

<div 
  id="cusdis_thread"
  data-host="https://mycusdis.vercel.app"
  data-app-id="0cc60d4f-6bae-4446-878d-43af68445b0e"
  data-page-id={pageId}
  data-page-url={pageUrl}
  data-page-title={pageTitle}
  class="mt-16 pt-8 border-t border-border/40"
  style="min-height: 200px;" 
></div>

<script is:inline>
  function initCusdis() {
    // 1. 如果腳本已經存在，就手動重新渲染
    if (window.CUSDIS) {
      console.log('Cusdis 已存在，執行重新渲染');
      window.CUSDIS.renderWidget();
      return;
    }

    // 2. 如果腳本還不存在，則建立並插入
    console.log('正在載入 Cusdis 腳本...');
    const script = document.createElement('script');
    script.src = 'https://mycusdis.vercel.app/js/cusdis.es.js';
    script.async = true;
    script.defer = true;
    document.body.appendChild(script);
  }

  // 處理第一次載入與 Astro 的 View Transitions 換頁
  document.addEventListener('astro:page-load', initCusdis);

  // 防呆：如果頁面已經載入完成了但腳本還沒跑
  if (document.readyState === 'complete') {
    initCusdis();
  }
</script>