---
// src/components/Cusdis.astro
const { pageId, pageUrl, pageTitle } = Astro.props;
const APP_ID = "3e3e4b8b-4e1c-4699-9386-6474aa099834";

// 💡 僅使用純粹的 iframe 請求，不載入任何外部 JS 腳本
const query = new URLSearchParams({
  appId: APP_ID,
  pageId: pageId,
  pageUrl: pageUrl,
  pageTitle: pageTitle
}).toString();

const iframeSrc = `https://cusdis.com/api/widget?${query}`;
---

<div class="cusdis-container mt-16 pt-8 border-t border-border/40">
  <iframe
    src={iframeSrc}
    style="width: 100%; min-height: 500px; border: 0;"
    id="cusdis-iframe"
    title="Comments"
    loading="lazy"
  ></iframe>
</div>

<script is:inline>
  // 這段腳本只處理高度，不涉及外部連線，比較不會被擋
  window.addEventListener('message', (e) => {
    try {
      const data = JSON.parse(e.data);
      if (data.target === 'cusdis' && data.type === 'resize') {
        const iframe = document.getElementById('cusdis-iframe');
        if (iframe) iframe.style.height = data.data + 'px';
      }
    } catch (err) {}
  });
</script>