---
// src/components/Cusdis.astro
const { pageId, pageUrl, pageTitle } = Astro.props;
const APP_ID = "3e3e4b8b-4e1c-4699-9386-6474aa099834";

// 💡 這裡是關鍵：將 widget 改成 iframe
// 並且手動把 pageUrl 進行最嚴格的編碼
const encodedUrl = encodeURIComponent(pageUrl);
const encodedTitle = encodeURIComponent(pageTitle);

const iframeSrc = `https://cusdis.com/api/iframe?appId=${APP_ID}&pageId=${pageId}&pageUrl=${encodedUrl}&pageTitle=${encodedTitle}`;
---

<div class="cusdis-container mt-16">
  <iframe
    src={iframeSrc}
    style="width: 100%; min-height: 500px; border: 0;"
    id="cusdis-iframe"
    title="Cusdis"
    loading="lazy"
  ></iframe>
</div>

<script is:inline>
  // 高度自適應
  window.addEventListener('message', (e) => {
    try {
      const data = JSON.parse(e.data);
      if (data.target === 'cusdis' && data.type === 'resize') {
        const iframe = document.getElementById('cusdis-iframe');
        if (iframe) iframe.style.height = data.data + 'px';
      }
    } catch (err) {}
  });
</script>