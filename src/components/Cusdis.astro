---
// src/components/Cusdis.astro
const { pageId, pageUrl, pageTitle } = Astro.props;

// 請再次確認這兩個 ID 是否與你 Cusdis 後台一致
const HOST = "https://mycusdis.vercel.app";
const APP_ID = "0cc60d4f-6bae-4446-878d-43af68445b0e";
---

<div class="cusdis-wrapper mt-16 pt-8 border-t border-border/40">
  <div 
    id="cusdis_thread"
    data-host={HOST}
    data-app-id={APP_ID}
    data-page-id={pageId}
    data-page-url={pageUrl}
    data-page-title={pageTitle}
    style="min-height: 200px; width: 100%;"
  ></div>
</div>

<script is:inline>
  function loadCusdis() {
    console.log("--- 執行 Cusdis 載入程序 ---");
    
    // 1. 清除舊的殘留
    const oldScript = document.getElementById('cusdis-lib');
    if (oldScript) oldScript.remove();

    // 2. 改從官方 CDN 抓取腳本，徹底解決 404 問題
    const script = document.createElement('script');
    script.id = 'cusdis-lib';
    script.src = 'https://cusdis.com/js/cusdis.es.js'; 
    script.async = true;
    script.defer = true;
    
    script.onload = () => {
      console.log("✅ 腳本從官方 CDN 載入成功");
      if (window.CUSDIS) {
        window.CUSDIS.renderWidget();
      }
    };

    script.onerror = () => {
      console.error("❌ 連官方 CDN 都連不上，請檢查網路或 AdBlock");
    };

    document.body.appendChild(script);
  }

  // 確保在 Astro 環境下正確執行
  document.addEventListener('astro:page-load', loadCusdis);
  
  // 初始載入處理
  if (document.readyState === 'complete') {
    loadCusdis();
  }
</script>