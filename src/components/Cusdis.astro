---
// src/components/Cusdis.astro
const { pageId, pageUrl, pageTitle } = Astro.props;
const APP_ID = "3e3e4b8b-4e1c-4699-9386-6474aa099834";
---

<div 
  id="cusdis_thread"
  data-host="https://cusdis.com"
  data-app-id={APP_ID}
  data-page-id={pageId}
  data-page-url={pageUrl}
  data-page-title={pageTitle}
></div>

<script async defer src="https://cusdis.com/js/cusdis.es.js"></script>

<script is:inline>
  function setCusdisTheme() {
    const thread = document.getElementById('cusdis_thread');
    if (!thread) return;

    const isDark = document.documentElement.classList.contains('dark');
    thread.setAttribute('data-theme', isDark ? 'dark' : 'light');

    if (window.CUSDIS) {
      window.CUSDIS.renderTo(thread);
    }
  }

  // 初始
  setCusdisTheme();

  // 監聽 dark mode 切換
  const observer = new MutationObserver(() => {
    setCusdisTheme();
  });

  observer.observe(document.documentElement, {
    attributes: true,
    attributeFilter: ['class'],
  });

  // ✅ 加上 resize（方案2）
  window.addEventListener('message', (e) => {
    try {
      const data = typeof e.data === 'string' ? JSON.parse(e.data) : e.data;

      if (data?.type === 'resize' && data?.height) {
        const iframe = document.querySelector('#cusdis_thread iframe');
        if (iframe) {
          iframe.style.height = (data.height + 80) + 'px';
        }
      }
    } catch {}
  });
</script>

<style>
  #cusdis_thread iframe {
    width: 100%;
    border: none;
    display: block;
  }
</style>